{
  "name": "@junui/ui",
  "version": "0.0.0",
  "description": "junui — React/Next.js component library. Curated 25~30 components on Radix Primitives + Tailwind.",
  "license": "MIT",
  "author": "modac",
  "homepage": "https://github.com/MODAC0/junui/tree/main/packages/ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MODAC0/junui.git",
    "directory": "packages/ui"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/styles.css",
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo storybook-static *.tsbuildinfo"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@junui/tokens": "workspace:*",
    "@junui/utils": "workspace:*",
    "class-variance-authority": "^0.7.1"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^9.1.10",
    "@storybook/addon-themes": "^9.1.10",
    "@storybook/react-vite": "^9.1.10",
    "@tailwindcss/vite": "^4.1.16",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^9.1.10",
    "tailwindcss": "^4.1.16",
    "tsup": "^8.3.5",
    "vite": "^6.0.5",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
