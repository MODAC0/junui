{
  "name": "@junui/tokens",
  "version": "0.0.0",
  "description": "Design tokens for junui (CSS variables + TypeScript exports + Tailwind theme).",
  "license": "MIT",
  "author": "modac",
  "homepage": "https://github.com/MODAC0/junui/tree/main/packages/tokens",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MODAC0/junui.git",
    "directory": "packages/tokens"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tokens.css": "./dist/tokens.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/tokens.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "tsup": "^8.3.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
