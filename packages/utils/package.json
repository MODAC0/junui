{
  "name": "@junui/utils",
  "version": "0.0.0",
  "description": "Shared utilities for junui (date, format, geo, validation helpers).",
  "license": "MIT",
  "author": "modac",
  "homepage": "https://github.com/MODAC0/junui/tree/main/packages/utils",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MODAC0/junui.git",
    "directory": "packages/utils"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "test": "echo 'no tests yet'",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "tsup": "^8.3.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
